# ============================================================
# STYLE APP — Environment Variables
# Copy this file to .env and fill in the values
# For Railway: add these in the Variables section of your service
# ============================================================

# ── Supabase (Client - Public) ──────────────────────────────
# Your Supabase project URL
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Your Supabase anon/public key (safe to expose in client)
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Supabase (Server - Secret) ───────────────────────────────
# Same URL as above (used by server.js for admin operations)
SUPABASE_URL=https://your-project-ref.supabase.co

# Service role key — NEVER expose this in client code!
# Found in: Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── Admin Authentication ────────────────────────────────────
# Email address for the admin login on Railway
AUTH_EMAIL=admin@yourdomain.com

# First password for admin login
AUTH_PASSWORD1=your-strong-password-1

# Second password (access key) for extra security
AUTH_PASSWORD2=your-strong-access-key-2

# Secret used to sign session tokens (use a long random string)
SESSION_SECRET=your-very-long-random-secret-key-here-minimum-32-chars

# ── Cloudinary (Media Uploads) ───────────────────────────────
# Found in: Cloudinary Dashboard → Settings → API Keys
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Server ───────────────────────────────────────────────────
# Port (Railway sets this automatically - do not change)
# PORT=3000

# Node environment
NODE_ENV=production
